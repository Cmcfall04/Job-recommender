# === Job Recommender Configuration ===

# Handshake (university job board)
HANDSHAKE_EMAIL=your-university-email@school.edu
HANDSHAKE_PASSWORD=your-password

# Optional: SerpAPI (only needed if Google Jobs via JobSpy is unreliable)
# SERPAPI_KEY=

# Optional: RapidAPI (only needed if LinkedIn via JobSpy is unreliable)
# RAPIDAPI_KEY=

# App settings
DATABASE_URL=sqlite:///./jobs.db
EMBEDDING_MODEL=all-MiniLM-L6-v2
FRONTEND_URL=http://localhost:5173
